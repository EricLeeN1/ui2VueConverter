    "prettier": "^3.2.0",
    "sharp": "^0.33.0",
    "vant": "^4.8.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@unocss/reset": "^0.58.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.27",
